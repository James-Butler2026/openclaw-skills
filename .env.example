# OpenClaw Skills - Environment Variables
# Kopiere diese Datei zu .env und fülle deine Werte ein
# ❌ NIE echte .env mit Passwörtern committen!

# ============================================================================
# TAVILY SEARCH API
# Hol dir einen Key bei: https://tavily.com/
# ============================================================================
TAVILY_API_KEY=tvly-dein_key_hier

# ============================================================================
# MAMMOUTH.AI API (für Claude Opus 4-6 Coding)
# Hol dir einen Key bei: https://mammouth.ai/
# ============================================================================
MAMMOUTH_API_KEY=sk-mammouth-dein_key_hier

# ============================================================================
# YOUTUBE DATA API v3
# Hol dir einen Key bei: https://console.cloud.google.com/apis/credentials
# Aktiviere die "YouTube Data API v3"
# ============================================================================
YOUTUBE_API_KEY=dein_youtube_api_key

# ============================================================================
# LEONARDO AI API (Bildgenerierung)
# Hol dir einen Key bei: https://leonardo.ai/ → Settings → API Keys
# ============================================================================
LEONARDO_API_KEY=dein_leonardo_key

# ============================================================================
# CLOUD STORAGE (MEGA)
# Mega.nz Account für Datei-Austausch
# ============================================================================
MEGA_EMAIL=dein_mega_email@beispiel.de
MEGA_PASSWORD=dein_mega_passwort

# ============================================================================
# WORDPRESS REST API
# ============================================================================
WORDPRESS_URL=https://dein-blog.de
WORDPRESS_USERNAME=dein_wp_benutzername
WORDPRESS_API_KEY=xxxx xxxx xxxx xxxx

# ============================================================================
# SUPERDATA API (YouTube Transkripte)
# Hol dir einen Key bei: https://supadata.ai/
# Free Plan = 100 Credits/Monat
# ============================================================================
SUPERDATA_API_KEY=sd_dein_key_hier

# ============================================================================
# Web.de Email Account (für E-Mail senden/lesen via IMAP/SMTP)
# ============================================================================
WEBDE_EMAIL=deine_email@web.de
WEBDE_PASSWORD=dein_passwort
WEBDE_IMAP_SERVER=imap.web.de
WEBDE_IMAP_PORT=993
WEBDE_USE_SSL=true

# ============================================================================
# GITHUB API (Skills veröffentlichen)
# Erstelle Token unter: https://github.com/settings/tokens
# Berechtigungen: repo, workflow, write:packages
# ============================================================================
GITHUB_TOKEN=ghp_dein_personal_access_token
GITHUB_USERNAME=dein_github_username
GITHUB_EMAIL=deine_email@beispiel.de

# ============================================================================
# IMGFILP API (Meme Generator)
# Erstelle kostenlosen Account bei: https://imgflip.com/signup
# ============================================================================
IMGFLIP_USERNAME=dein_imgflip_username
IMGFLIP_PASSWORD=dein_imgflip_passwort

# ============================================================================
# PIPER TTS (Lokale deutsche Sprachsynthese)
# Diese Pfade müssen gesetzt sein, damit Piper funktioniert!
# ============================================================================
export LD_LIBRARY_PATH=/home/node/.local/lib/piper:$LD_LIBRARY_PATH
export ESPEAK_DATA_PATH=/usr/lib/x86_64-linux-gnu/espeak-ng-data
PIPER_MODEL_PATH=/usr/local/share/piper-voices
PIPER_VOICE=de_DE-thorsten-medium

# ============================================================================
# NOTIFICATION SETTINGS
# ============================================================================
NOTIFY_CHANNEL=telegram

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
